# Poondurai Kaadai Admin - Environment Variables
# Copy this file to .env and update values as needed

# API base URL (update when backend is ready)
VITE_API_BASE_URL=http://localhost:3000/api

# App title (optional)
VITE_APP_TITLE=Poondurai Kaadai Admin

# Cloudinary - for delete (temporary, move to backend later)
# Get from: https://console.cloudinary.com → Settings → API Keys
# WARNING: API secret will be exposed in client bundle - use backend when possible
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_API_SECRET=
